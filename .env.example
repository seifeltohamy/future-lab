# LLM Configuration (supports any OpenAI SDK-compatible API)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL_NAME=gemini-2.0-flash

# Zep Cloud memory graph — free tier available: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# Optional: second LLM for Reddit simulation (delete these lines if unused)
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here

# Frontend API URL — set to your Railway backend service URL
VITE_API_BASE_URL=https://your-backend.up.railway.app